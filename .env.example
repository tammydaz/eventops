# Copy to .env and fill in your values. Never commit .env
# Base ID and table IDs — used in client for building paths (safe, not secrets)
VITE_AIRTABLE_BASE_ID=your_base_id_here
VITE_AIRTABLE_EVENTS_TABLE=your_table_id_here
# Event Menu (SHADOW SYSTEM): set to your table ID (tbl...) to avoid URL encoding issues. Optional — defaults to table name.
# VITE_AIRTABLE_EVENT_MENU_SHADOW_TABLE=tblYourEventMenuShadowTableId

# Airtable API key — SERVER-SIDE ONLY. Set in .env for local dev:full, and in Vercel for production.
# Never use VITE_ prefix — the key would be exposed to the browser.
AIRTABLE_API_KEY=your_airtable_token_here
AIRTABLE_BASE_ID=your_base_id_here

# OpenAI — server-side only (invoice parsing)
OPENAI_API_KEY=your_openai_key_here
