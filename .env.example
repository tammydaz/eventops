# Airtable — required for EventOps
# Create token at: https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write, schema.bases:read
# Ensure the token has access to your base.
VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=
VITE_AIRTABLE_EVENTS_TABLE=

# Optional — override defaults if your base uses different table IDs
# VITE_AIRTABLE_STATIONS_TABLE=tblhFwUfREbpfFXhv
# VITE_AIRTABLE_MENU_ITEMS_TABLE=tbl0aN33DGG6R1sPZ

# Station Presets — table name or ID for preset loading when adding stations
# Default: "Station Presets" if unset. Proxy uses server-side AIRTABLE_* vars.
# VITE_AIRTABLE_STATION_PRESETS_TABLE=Station Presets
# VITE_AIRTABLE_STATION_PRESETS_NAME_FIELD=Preset Name   # or "Station Type", "Name" — field used to match preset by name

# Dispatch & Deliveries Hub — autopopulate full-service fields from Airtable
# Add field IDs when you create these fields in your Events table
# VITE_AIRTABLE_DISPATCH_SERVER_NAME_FIELD=   # Server Name (full-service) — add when available
# VITE_AIRTABLE_DISPATCH_VAN_NUMBER_FIELD=   # Van # (full-service) — add when available
