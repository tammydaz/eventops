# Copy to .env and fill in your values. Never commit .env
# Base ID and table IDs — used in client for building paths (safe, not secrets)
VITE_AIRTABLE_BASE_ID=your_base_id_here
VITE_AIRTABLE_EVENTS_TABLE=your_table_id_here
# Event Menu (SHADOW SYSTEM): set to your table ID (tbl...) to avoid URL encoding issues. Optional — defaults to table name.
# VITE_AIRTABLE_EVENT_MENU_SHADOW_TABLE=tblYourEventMenuShadowTableId

# Menu_Lab table — catalog for delivery section pickers. Optional — defaults to tbl6gXRT2FPpTdf0J.
# VITE_AIRTABLE_MENU_LAB_TABLE=tbl6gXRT2FPpTdf0J

# Optional: where Vite proxies /api during npm run dev / npm run preview (defaults to production Vercel URL in vite.config.js).
# VITE_DEV_API_PROXY=https://your-deployment.vercel.app

# Airtable API key — SERVER-SIDE ONLY. Set in .env for local dev:full, and in Vercel for production.
# Never use VITE_ prefix — the key would be exposed to the browser.
AIRTABLE_API_KEY=your_airtable_token_here
AIRTABLE_BASE_ID=your_base_id_here

# OpenAI — server-side only (invoice parsing)
OPENAI_API_KEY=your_openai_key_here

# Optional: override FW Staff Summary Long text field ID (defaults to fld7SuoE1E5XcfEyT in code)
# VITE_AIRTABLE_FW_STAFF_SUMMARY_FIELD=fld7SuoE1E5XcfEyT

# Optional: override Staffing confirmed (Nowsta) checkbox field ID (defaults to fldTXOxU0iNUD7pKK in code)
# VITE_AIRTABLE_STAFFING_CONFIRMED_FIELD=fldTXOxU0iNUD7pKK

# FOH Intake list sidebar — create checkbox fields on Events table, then set field IDs:
# VITE_AIRTABLE_FOH_BEO_FIRED_FIELD=fldYourBeoFiredFieldId
# VITE_AIRTABLE_FOH_SPECK_COMPLETE_FIELD=fldYourSpeckCompleteFieldId
